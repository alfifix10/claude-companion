# Auto-detect text vs binary, normalize line endings to LF on commit.
# Silences the recurring "LF will be replaced by CRLF" warnings on
# Windows without actually changing anything on disk — Chromium
# extensions, Node, and shell scripts all prefer LF.
* text=auto eol=lf

# Keep Windows-only scripts as CRLF so PowerShell / CMD stay happy.
*.bat    text eol=crlf
*.ps1    text eol=crlf

# Binaries — never touch.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pem    binary
